<%- include('../../partials/head', { title: 'Editar práctica' }) %>
<body>
<div class="sitio">
    <%- include('../../partials/header', { active: 'practicas' }) %>

    <main class="contenido">
        <div class="contenido-estrecho">
            <header class="cabecera-pagina">
                <div>
                    <h1>Editar práctica</h1>
                    <p>Actualizá los datos de la propuesta y su estado de publicación.</p>
                </div>
            </header>

            <% if (error) { %>
                <div class="alerta" role="alert"><%= error %></div>
            <% } %>

            <form class="formulario formulario-grid" action="/profesor/practicas/<%= practica.id %>?_method=PUT" method="POST">
                <div class="campo campo-completo">
                    <label for="titulo">Título de la práctica</label>
                    <input id="titulo" type="text" name="titulo" value="<%= practica.titulo %>" required autofocus>
                </div>

                <div class="campo campo-completo">
                    <label for="descripcion">Descripción</label>
                    <textarea id="descripcion" name="descripcion"><%= practica.descripcion || '' %></textarea>
                </div>

                <div class="campo">
                    <label for="materiaId">Materia y carrera</label>
                    <select id="materiaId" name="materiaId" required>
                        <% materias.forEach(materia => { %>
                            <option value="<%= materia.id %>" <%= materia.id === practica.materiaId ? 'selected' : '' %>><%= materia.nombre %> · <%= materia.carrera.nombre %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="campo">
                    <label for="lugar">Lugar</label>
                    <input id="lugar" type="text" name="lugar" value="<%= practica.lugar %>" required>
                </div>

                <div class="campo">
                    <label for="fechaInicio">Fecha de inicio</label>
                    <input id="fechaInicio" type="date" name="fechaInicio" value="<%= practica.fechaInicio %>" required>
                </div>

                <div class="campo">
                    <label for="fechaFin">Fecha de finalización</label>
                    <input id="fechaFin" type="date" name="fechaFin" value="<%= practica.fechaFin || '' %>">
                </div>

                <div class="campo">
                    <label for="horarioInicio">Horario de inicio</label>
                    <input id="horarioInicio" type="time" name="horarioInicio" value="<%= practica.horarioInicio %>" required>
                </div>

                <div class="campo">
                    <label for="horarioFin">Horario de finalización</label>
                    <input id="horarioFin" type="time" name="horarioFin" value="<%= practica.horarioFin %>" required>
                </div>

                <div class="campo">
                    <label for="cupo">Cupo disponible</label>
                    <input id="cupo" type="number" name="cupo" min="1" value="<%= practica.cupo %>" required>
                </div>

                <div class="campo">
                    <label for="estado">Estado</label>
                    <select id="estado" name="estado">
                        <option value="ACTIVA" <%= practica.estado === 'ACTIVA' ? 'selected' : '' %>>Activa</option>
                        <option value="INACTIVA" <%= practica.estado === 'INACTIVA' ? 'selected' : '' %>>Inactiva</option>
                    </select>
                </div>

                <div class="campo campo-completo">
                    <span class="grupo-etiqueta">Días de cursada</span>
                    <div class="opciones-check">
                        <% dias.forEach(dia => { %>
                            <label class="opcion-check">
                                <input type="checkbox" name="dias" value="<%= dia.id %>" <%= diasSeleccionados.includes(dia.id) ? 'checked' : '' %>>
                                <%= dia.nombre %>
                            </label>
                        <% }) %>
                    </div>
                </div>

                <div class="campo campo-completo">
                    <label for="observaciones">Observaciones</label>
                    <textarea id="observaciones" name="observaciones"><%= practica.observaciones || '' %></textarea>
                </div>

                <div class="formulario-acciones">
                    <button class="boton" type="submit">Guardar cambios</button>
                    <a class="boton boton-secundario" href="/profesor/mis-practicas">Cancelar</a>
                </div>
            </form>
        </div>
    </main>

    <script>
        const fechaInicio = document.getElementById('fechaInicio');
        const fechaFin = document.getElementById('fechaFin');
        const horarioInicio = document.getElementById('horarioInicio');
        const horarioFin = document.getElementById('horarioFin');

        function validarFechas() {
            fechaFin.min = fechaInicio.value;
            fechaFin.setCustomValidity(
                fechaFin.value && fechaFin.value < fechaInicio.value
                    ? 'La fecha de finalización no puede ser anterior al inicio.'
                    : ''
            );
        }

        function validarHorarios() {
            horarioFin.setCustomValidity(
                horarioInicio.value && horarioFin.value && horarioFin.value <= horarioInicio.value
                    ? 'El horario de finalización debe ser posterior al inicio.'
                    : ''
            );
        }

        fechaInicio.addEventListener('change', validarFechas);
        fechaFin.addEventListener('change', validarFechas);
        horarioInicio.addEventListener('change', validarHorarios);
        horarioFin.addEventListener('change', validarHorarios);
        validarFechas();
        validarHorarios();
    </script>

    <%- include('../../partials/footer') %>
