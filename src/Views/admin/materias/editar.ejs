<%- include('../../partials/head', { title: 'Editar materia' }) %>
<body>
<div class="sitio">
    <%- include('../../partials/header', { active: 'materias' }) %>

    <main class="contenido">
        <div class="contenido-estrecho">
            <header class="cabecera-pagina">
                <div>
                    <h1>Editar materia</h1>
                    <p>Actualizá sus datos, carrera asociada o estado de publicación.</p>
                </div>
            </header>

            <% if (error) { %>
                <div class="alerta" role="alert"><%= error %></div>
            <% } %>

            <form class="formulario formulario-grid" action="/admin/materias/<%= materia.id %>?_method=PUT" method="POST">
                <div class="campo">
                    <label for="nombre">Nombre de la materia</label>
                    <input id="nombre" type="text" name="nombre" value="<%= materia.nombre %>" required autofocus>
                </div>

                <div class="campo">
                    <label for="carreraId">Carrera</label>
                    <select id="carreraId" name="carreraId" required>
                        <% carreras.forEach(carrera => { %>
                            <option value="<%= carrera.id %>" <%= carrera.id === materia.carreraId ? 'selected' : '' %>><%= carrera.nombre %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="campo campo-completo">
                    <label for="descripcion">Descripción</label>
                    <textarea id="descripcion" name="descripcion"><%= materia.descripcion || '' %></textarea>
                </div>

                <div class="campo">
                    <label for="estado">Estado</label>
                    <select id="estado" name="estado">
                        <option value="ACTIVA" <%= materia.estado === 'ACTIVA' ? 'selected' : '' %>>Activa</option>
                        <option value="INACTIVA" <%= materia.estado === 'INACTIVA' ? 'selected' : '' %>>Inactiva</option>
                    </select>
                </div>

                <div class="formulario-acciones">
                    <button class="boton" type="submit">Guardar cambios</button>
                    <a class="boton boton-secundario" href="/admin/materias">Cancelar</a>
                </div>
            </form>
        </div>
    </main>

    <%- include('../../partials/footer') %>
