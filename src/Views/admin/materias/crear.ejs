<%- include('../../partials/head', { title: 'Nueva materia' }) %>
<body>
<div class="sitio">
    <%- include('../../partials/header', { active: 'materias' }) %>

    <main class="contenido">
        <div class="contenido-estrecho">
            <header class="cabecera-pagina">
                <div>
                    <h1>Nueva materia</h1>
                    <p>Creá una materia y vinculala con la carrera correspondiente.</p>
                </div>
            </header>

            <% if (error) { %>
                <div class="alerta" role="alert"><%= error %></div>
            <% } %>

            <form class="formulario formulario-grid" action="/admin/materias/crear" method="POST">
                <div class="campo">
                    <label for="nombre">Nombre de la materia</label>
                    <input id="nombre" type="text" name="nombre" required autofocus>
                </div>

                <div class="campo">
                    <label for="carreraId">Carrera</label>
                    <select id="carreraId" name="carreraId" required>
                        <option value="" disabled selected>Seleccioná una carrera</option>
                        <% carreras.forEach(carrera => { %>
                            <option value="<%= carrera.id %>"><%= carrera.nombre %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="campo campo-completo">
                    <label for="descripcion">Descripción</label>
                    <textarea id="descripcion" name="descripcion" placeholder="Agregá una descripción breve de la materia"></textarea>
                </div>

                <div class="formulario-acciones">
                    <button class="boton" type="submit">Guardar materia</button>
                    <a class="boton boton-secundario" href="/admin/materias">Cancelar</a>
                </div>
            </form>
        </div>
    </main>

    <%- include('../../partials/footer') %>
