<%- include('../partials/head', { title: 'Mi perfil' }) %>
<body>
<div class="sitio">
    <%- include('../partials/header', { active: 'perfil' }) %>

    <main class="contenido">
        <div class="contenido-estrecho">
            <header class="cabecera-pagina">
                <div>
                    <h1>Mi perfil</h1>
                    <p>Actualizá tus datos personales y la información de acceso a tu cuenta.</p>
                </div>
            </header>

            <% if (error) { %>
                <div class="alerta" role="alert"><%= error %></div>
            <% } %>

            <% if (success) { %>
                <div class="alerta-exito" role="status">Tus datos se actualizaron correctamente.</div>
            <% } %>

            <form class="formulario formulario-grid" action="<%= profileBase %>/perfil?_method=PUT" method="POST">
                <% if (user.rol === 'ALUMNO') { %>
                    <div class="dato-bloqueado">
                        <span>DNI</span>
                        <strong><%= usuario.dni %></strong>
                    </div>
                <% } else { %>
                    <div class="campo">
                        <label for="dni">DNI</label>
                        <input id="dni" type="text" name="dni" value="<%= usuario.dni %>" inputmode="numeric" autocomplete="username" required>
                    </div>
                <% } %>

                <div class="campo">
                    <label for="email">Correo electrónico</label>
                    <input id="email" type="email" name="email" value="<%= usuario.email %>" autocomplete="email" required>
                </div>

                <% if (user.rol === 'ALUMNO') { %>
                    <div class="dato-bloqueado">
                        <span>Apellido</span>
                        <strong><%= usuario.apellido %></strong>
                    </div>

                    <div class="dato-bloqueado">
                        <span>Nombre</span>
                        <strong><%= usuario.nombre %></strong>
                    </div>
                <% } else { %>
                    <div class="campo">
                        <label for="apellido">Apellido</label>
                        <input id="apellido" type="text" name="apellido" value="<%= usuario.apellido %>" autocomplete="family-name" required>
                    </div>

                    <div class="campo">
                        <label for="nombre">Nombre</label>
                        <input id="nombre" type="text" name="nombre" value="<%= usuario.nombre %>" autocomplete="given-name" required>
                    </div>
                <% } %>

                <div class="campo">
                    <label for="celular">Celular</label>
                    <input id="celular" type="tel" name="celular" value="<%= usuario.celular || '' %>" autocomplete="tel">
                </div>

                <div class="campo">
                    <label for="fechaNacimiento">Fecha de nacimiento</label>
                    <input id="fechaNacimiento" type="date" name="fechaNacimiento" value="<%= usuario.fechaNacimiento || '' %>">
                </div>

                <div class="campo">
                    <label for="genero">Género</label>
                    <% const generoActual = String(usuario.genero || '').toUpperCase(); %>
                    <select id="genero" name="genero">
                        <option value="" <%= !generoActual ? 'selected' : '' %>>Prefiero no indicarlo</option>
                        <option value="FEMENINO" <%= generoActual === 'FEMENINO' ? 'selected' : '' %>>Femenino</option>
                        <option value="MASCULINO" <%= generoActual === 'MASCULINO' ? 'selected' : '' %>>Masculino</option>
                        <option value="OTRO" <%= generoActual === 'OTRO' ? 'selected' : '' %>>Otro</option>
                    </select>
                </div>

                <% if (user.rol === 'PROFESOR') { %>
                    <section class="seccion-formulario campo-completo">
                        <div>
                            <h2>Información académica</h2>
                            <p>Podés agregar todas las carreras y materias en las que dictás clases.</p>
                        </div>

                        <div class="campo campo-completo">
                            <span class="grupo-etiqueta">Carreras</span>
                            <div class="opciones-check">
                                <% carreras.forEach(carrera => { %>
                                    <label class="opcion-check">
                                        <input
                                            type="checkbox"
                                            name="carreras"
                                            value="<%= carrera.id %>"
                                            data-carrera-check
                                            <%= carrerasSeleccionadas.includes(carrera.id) ? 'checked' : '' %>>
                                        <%= carrera.nombre %>
                                    </label>
                                <% }) %>
                            </div>
                        </div>

                        <div class="campo campo-completo">
                            <span class="grupo-etiqueta">Materias</span>
                            <div class="lista-materias-perfil">
                                <% materias.forEach(materia => { %>
                                    <label class="opcion-check" data-materia-opcion data-carrera-id="<%= materia.carreraId %>">
                                        <input
                                            type="checkbox"
                                            name="materias"
                                            value="<%= materia.id %>"
                                            <%= materiasSeleccionadas.includes(materia.id) ? 'checked' : '' %>>
                                        <span><%= materia.nombre %> <small>· <%= materia.carrera.nombre %></small></span>
                                    </label>
                                <% }) %>
                            </div>
                        </div>
                    </section>
                <% } else if (user.rol === 'ALUMNO') { %>
                    <section class="seccion-formulario campo-completo">
                        <div>
                            <h2>Información académica</h2>
                            <p>Tu carrera determina qué prácticas vas a ver disponibles.</p>
                        </div>

                        <div class="dato-bloqueado">
                            <span>Carrera</span>
                            <strong><%= alumno && alumno.carrera ? alumno.carrera.nombre : 'Sin carrera asignada' %></strong>
                            <small>La carrera se define al crear la cuenta y no puede modificarse desde el perfil.</small>
                        </div>
                    </section>
                <% } %>

                <section class="seccion-formulario campo-completo">
                    <div>
                        <h2>Cambiar contraseña</h2>
                        <p>Dejá estos campos vacíos si no querés modificarla.</p>
                    </div>

                    <div class="formulario-grid">
                        <div class="campo campo-completo">
                            <label for="passwordActual">Contraseña actual</label>
                            <input id="passwordActual" type="password" name="passwordActual" autocomplete="current-password">
                        </div>

                        <div class="campo">
                            <label for="passwordNueva">Nueva contraseña</label>
                            <input id="passwordNueva" type="password" name="passwordNueva" minlength="8" autocomplete="new-password">
                            <small>Mínimo 8 caracteres.</small>
                        </div>

                        <div class="campo">
                            <label for="passwordConfirmacion">Confirmar contraseña</label>
                            <input id="passwordConfirmacion" type="password" name="passwordConfirmacion" minlength="8" autocomplete="new-password">
                        </div>
                    </div>
                </section>

                <div class="formulario-acciones">
                    <button class="boton" type="submit">Guardar cambios</button>
                    <a class="boton boton-secundario" href="<%= profileBase %>/dashboard">Volver al panel</a>
                </div>
            </form>
        </div>
    </main>

<% if (user.rol === 'PROFESOR') { %>
    <script>
        const carreras = Array.from(document.querySelectorAll('[data-carrera-check]'));
        const materias = Array.from(document.querySelectorAll('[data-materia-opcion]'));

        function filtrarMaterias() {
            const carrerasSeleccionadas = new Set(
                carreras.filter(input => input.checked).map(input => input.value)
            );

            materias.forEach(label => {
                const visible = carrerasSeleccionadas.has(label.dataset.carreraId);
                const input = label.querySelector('input');

                label.classList.toggle('oculto', !visible);
                input.disabled = !visible;
                if (!visible) input.checked = false;
            });
        }

        carreras.forEach(input => input.addEventListener('change', filtrarMaterias));
        filtrarMaterias();
    </script>
<% } %>

    <%- include('../partials/footer') %>
