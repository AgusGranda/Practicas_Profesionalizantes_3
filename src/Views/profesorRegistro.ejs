<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= titulo %></title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <main class="contenedor chico">
        <a class="volver" href="/login">Volver al ingreso</a>
        <h1><%= titulo %></h1>
        <p>Completa tus datos. El admin revisa la solicitud y habilita el acceso.</p>

        <% if (error) { %>
            <p class="alerta"><%= error %></p>
        <% } %>

        <% if (exito) { %>
            <p class="ok"><%= exito %></p>
        <% } %>

        <form class="formulario" action="/profesor/registro" method="POST">
            <label for="apellidoNombre">Apellido y nombre</label>
            <input id="apellidoNombre" name="apellidoNombre" type="text" required>

            <label for="email">Mail</label>
            <input id="email" name="email" type="email" required>

            <label for="dni">Usuario / DNI</label>
            <input id="dni" name="dni" type="text" required>

            <label for="password">Clave</label>
            <input id="password" name="password" type="password" required>

            <button class="boton" type="submit">Crear perfil</button>
        </form>
    </main>
</body>
</html>
