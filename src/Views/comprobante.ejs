<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= titulo %></title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <main class="contenedor chico comprobante">
        <a class="volver no-print" href="/alumno">Volver a mi perfil</a>
        <h1><%= titulo %></h1>

        <section class="panel">
            <p class="etiqueta">Estado</p>
            <% if (inscripcion.estado === 'INSCRIPTO') { %>
                <span class="estado disponible">Inscripto</span>
            <% } else { %>
                <span class="estado espera">En lista de espera</span>
            <% } %>
        </section>

        <dl class="detalle">
            <div>
                <dt>DNI</dt>
                <dd><%= inscripcion.alumno.dni %></dd>
            </div>
            <div>
                <dt>Apellido y nombre</dt>
                <dd><%= inscripcion.alumno.apellidoNombre %></dd>
            </div>
            <div>
                <dt>Carrera</dt>
                <dd><%= inscripcion.carreraAlumno.nombre %></dd>
            </div>
            <div>
                <dt>Practica</dt>
                <dd><%= inscripcion.grupo.practica.nombre %></dd>
            </div>
            <div>
                <dt>Lugar</dt>
                <dd><%= inscripcion.grupo.lugar %></dd>
            </div>
            <div>
                <dt>Dias y horario</dt>
                <dd><%= inscripcion.grupo.dia %>, <%= inscripcion.grupo.horario %></dd>
            </div>
            <div>
                <dt>Profesor</dt>
                <dd><%= inscripcion.grupo.profesor.apellidoNombre %></dd>
            </div>
        </dl>

        <a class="boton no-print" href="/inscripcion/comprobante/<%= inscripcion.id %>/pdf">Descargar PDF</a>
        <button class="boton secundario no-print" onclick="window.print()">Imprimir</button>
    </main>
</body>
</html>
