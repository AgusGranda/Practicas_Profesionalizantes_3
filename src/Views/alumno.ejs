<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= titulo %></title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <main class="contenedor">
        <a class="volver" href="/">Volver al inicio</a>
        <h1><%= titulo %></h1>

        <% if (error) { %>
            <p class="alerta"><%= error %></p>
        <% } %>

        <% if (exito) { %>
            <p class="ok"><%= exito %></p>
        <% } %>

        <section class="layout-doble">
            <form class="formulario" action="/alumno" method="POST">
                <h2>Datos personales</h2>

                <label for="dni">DNI</label>
                <input id="dni" type="text" value="<%= alumno.dni %>" disabled>

                <label for="apellidoNombre">Apellido y nombre</label>
                <input id="apellidoNombre" name="apellidoNombre" type="text" value="<%= alumno.apellidoNombre %>" required>

                <label for="fechaNacimiento">Fecha de nacimiento</label>
                <input id="fechaNacimiento" name="fechaNacimiento" type="date" value="<%= alumno.fechaNacimiento %>" required>

                <label for="email">Mail</label>
                <input id="email" name="email" type="email" value="<%= alumno.email %>" required>

                <label for="telefono">Telefono</label>
                <input id="telefono" name="telefono" type="text" value="<%= alumno.telefono %>" required>

                <label for="carreraId">Carrera</label>
                <select id="carreraId" name="carreraId" required>
                    <% carreras.forEach(function(carrera) { %>
                        <option value="<%= carrera.id %>" <%= alumno.carreraId === carrera.id ? 'selected' : '' %>><%= carrera.nombre %></option>
                    <% }); %>
                </select>

                <label for="anio">Ano</label>
                <input id="anio" name="anio" type="number" min="1" max="5" value="<%= alumno.anio %>" required>

                <button class="boton" type="submit">Guardar datos</button>
            </form>

            <section class="panel">
                <h2>Mi practica</h2>
                <% if (!inscripcion) { %>
                    <p>No tenes una inscripcion activa.</p>
                    <a class="boton" href="/practicas">Ver practicas</a>
                <% } else { %>
                    <dl class="detalle-simple">
                        <div>
                            <dt>Estado</dt>
                            <dd><%= inscripcion.estado %></dd>
                        </div>
                        <div>
                            <dt>Practica</dt>
                            <dd><%= inscripcion.grupo.practica.nombre %></dd>
                        </div>
                        <div>
                            <dt>Lugar</dt>
                            <dd><%= inscripcion.grupo.lugar %></dd>
                        </div>
                        <div>
                            <dt>Dias y horario</dt>
                            <dd><%= inscripcion.grupo.dia %>, <%= inscripcion.grupo.horario %></dd>
                        </div>
                    </dl>

                    <a class="boton secundario" href="/inscripcion/comprobante/<%= inscripcion.id %>">Ver comprobante</a>
                    <form action="/alumno/inscripciones/<%= inscripcion.id %>/cancelar" method="POST">
                        <button class="boton peligro" type="submit">Darme de baja</button>
                    </form>
                <% } %>
            </section>
        </section>
    </main>
</body>
</html>
