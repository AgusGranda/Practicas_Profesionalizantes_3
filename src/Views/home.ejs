<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= titulo %></title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <main class="contenedor">
        <h1><%= titulo %></h1>
        <p>Bienvenido al sistema de inscripcion a practicas profesionalizantes.</p>

        <a class="boton" href="/practicas">Ver practicas disponibles</a>
        <% if (!usuario) { %>
            <a class="boton secundario" href="/login">Ingresar</a>
        <% } else { %>
            <form class="form-inline" action="/logout" method="POST">
                <button class="boton secundario" type="submit">Salir</button>
            </form>
        <% } %>
    </main>
</body>
</html>
