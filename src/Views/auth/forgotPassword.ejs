<%- include('../partials/head', { title: 'Recuperar contraseña' }) %>
<body>
    <main class="auth-pagina">
        <section class="auth-panel">
            <%- include('../partials/brand') %>

            <div class="auth-contenido">
                <h1>Recuperar contraseña</h1>
                <p>Ingresá el correo asociado a tu cuenta y te enviaremos un enlace de recuperación.</p>

                <% if (error) { %>
                    <div class="alerta" role="alert"><%= error %></div>
                <% } %>

                <% if (success) { %>
                    <div class="alerta-exito" role="status">
                        Si el correo está registrado, recibirás un enlace válido durante 30 minutos.
                    </div>
                <% } else { %>
                    <form class="auth-formulario" action="/auth/forgot-password" method="POST">
                        <div class="campo">
                            <label for="email">Correo electrónico</label>
                            <input id="email" type="email" name="email" autocomplete="email" required autofocus>
                        </div>

                        <button class="boton" type="submit">Enviar enlace</button>
                    </form>
                <% } %>

                <p class="auth-ayuda"><a href="/auth/login">Volver al ingreso</a></p>
            </div>
        </section>

        <aside class="auth-visual" aria-hidden="true">
            <div class="auth-mensaje">
                <h2>Recuperá el acceso de forma segura.</h2>
                <p>El enlace es personal, vence rápidamente y solo puede utilizarse una vez.</p>
            </div>
        </aside>
    </main>
</body>
</html>
