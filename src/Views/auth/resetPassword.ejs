<%- include('../partials/head', { title: 'Nueva contraseña' }) %>
<body>
    <main class="auth-pagina">
        <section class="auth-panel">
            <%- include('../partials/brand') %>

            <div class="auth-contenido">
                <h1>Nueva contraseña</h1>
                <p>Elegí una contraseña segura de al menos 8 caracteres.</p>

                <% if (error) { %>
                    <div class="alerta" role="alert"><%= error %></div>
                <% } %>

                <% if (valid) { %>
                    <form class="auth-formulario" action="/auth/reset-password/<%= token %>" method="POST">
                        <div class="campo">
                            <label for="password">Nueva contraseña</label>
                            <input id="password" type="password" name="password" minlength="8" autocomplete="new-password" required autofocus>
                        </div>

                        <div class="campo">
                            <label for="confirmacion">Confirmar contraseña</label>
                            <input id="confirmacion" type="password" name="confirmacion" minlength="8" autocomplete="new-password" required>
                        </div>

                        <button class="boton" type="submit">Guardar contraseña</button>
                    </form>
                <% } else { %>
                    <a class="boton" href="/auth/forgot-password">Solicitar otro enlace</a>
                <% } %>

                <p class="auth-ayuda"><a href="/auth/login">Volver al ingreso</a></p>
            </div>
        </section>

        <aside class="auth-visual" aria-hidden="true">
            <div class="auth-mensaje">
                <h2>Estás a un paso de volver.</h2>
                <p>La nueva contraseña reemplazará inmediatamente a la anterior.</p>
            </div>
        </aside>
    </main>
</body>
</html>
