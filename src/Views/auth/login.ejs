<%- include('../partials/head', { title: 'Iniciar sesión' }) %>
<body>
    <main class="auth-pagina">
        <section class="auth-panel">
            <%- include('../partials/brand') %>

            <div class="auth-contenido">
                <h1>Bienvenido</h1>
                <p>Ingresá con tus datos para acceder a tu espacio de prácticas.</p>

                <% if (error) { %>
                    <div class="alerta" role="alert"><%= error %></div>
                <% } %>

                <form class="auth-formulario" action="/auth/login" method="POST">
                    <div class="campo">
                        <label for="dni">DNI</label>
                        <input id="dni" type="text" name="dni" inputmode="numeric" autocomplete="username" placeholder="Ingresá tu DNI" required autofocus>
                    </div>

                    <div class="campo">
                        <label for="password">Contraseña</label>
                        <input id="password" type="password" name="password" autocomplete="current-password" placeholder="Ingresá tu contraseña" required>
                    </div>

                    <button class="boton" type="submit">Ingresar</button>
                </form>

                <p class="auth-ayuda">
                    ¿Todavía no tenés cuenta?
                    <a href="/auth/register">Crear una cuenta</a>
                </p>
            </div>
        </section>

        <aside class="auth-visual" aria-hidden="true">
            <div class="auth-mensaje">
                <h2>Tu experiencia profesional empieza acá.</h2>
                <p>Encontrá prácticas, gestioná inscripciones y conectá la formación académica con el mundo laboral.</p>
            </div>
        </aside>
    </main>
</body>
</html>
