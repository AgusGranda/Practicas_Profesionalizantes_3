<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= titulo %></title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <main class="contenedor chico">
        <a class="volver" href="/profesor">Volver al panel</a>
        <h1><%= titulo %></h1>

        <% if (error) { %>
            <p class="alerta"><%= error %></p>
        <% } %>

        <form class="formulario" action="<%= action %>" method="POST">
            <label for="nombre">Nombre de la practica</label>
            <input id="nombre" name="nombre" type="text" value="<%= grupo ? grupo.practica.nombre : '' %>" required>

            <label for="carreraId">Carrera</label>
            <select id="carreraId" name="carreraId" required>
                <% carreras.forEach(function(carrera) { %>
                    <option value="<%= carrera.id %>" <%= grupo && grupo.practica.carreraId === carrera.id ? 'selected' : '' %>><%= carrera.nombre %></option>
                <% }); %>
            </select>

            <label for="descripcion">Descripcion</label>
            <textarea id="descripcion" name="descripcion" rows="4" required><%= grupo ? grupo.practica.descripcion : '' %></textarea>

            <label for="lugar">Lugar</label>
            <input id="lugar" name="lugar" type="text" value="<%= grupo ? grupo.lugar : '' %>" required>

            <label for="dia">Dias</label>
            <input id="dia" name="dia" type="text" value="<%= grupo ? grupo.dia : '' %>" required>

            <label for="horario">Horario</label>
            <input id="horario" name="horario" type="text" value="<%= grupo ? grupo.horario : '' %>" required>

            <label for="cupoMaximo">Cupo maximo</label>
            <input id="cupoMaximo" name="cupoMaximo" type="number" min="1" value="<%= grupo ? grupo.cupoMaximo : 1 %>" required>

            <button class="boton" type="submit">Guardar practica</button>
        </form>
    </main>
</body>
</html>
